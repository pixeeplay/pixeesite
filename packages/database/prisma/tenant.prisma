// Pixeesite — Tenant DB schema
// Ce schéma est appliqué sur chaque DB tenant (1 DB = 1 client).
// L'orgId n'apparaît PAS dans les tables car la DB elle-même est l'isolation.

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/tenant-client"
}

datasource db {
  provider = "postgresql"
  url      = env("TENANT_DATABASE_URL") // remplacé à runtime par tenant URL
}

// ─── PAGE BUILDER ──────────────────────────────────────────────

model SitePage {
  id        String   @id @default(cuid())
  siteId    String   // ref Site dans platform DB (string libre côté tenant)
  slug      String   // "/" "/about" "/p/foo"
  title     String
  meta      Json?    // { description, ogImage, robots, ... }
  blocks    Json     // [ { type, width, data, effect, effectDelay, ... } ]
  visible   Boolean  @default(true)
  isHome    Boolean  @default(false)
  // SEO
  noIndex   Boolean  @default(false)
  canonical String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@unique([siteId, slug])
  @@index([siteId, visible])
}

// ─── LEADS / CRM ───────────────────────────────────────────────

model Lead {
  id            String   @id @default(cuid())
  email         String?  @unique
  firstName     String?
  lastName      String?
  phone         String?
  company       String?
  jobTitle      String?
  city          String?
  country       String?
  source        String   @default("manual")
  sourceDetail  String?
  status        String   @default("new")
  score         Int      @default(0)
  tags          String[] @default([])
  segments      String[] @default([])
  notes         String?  @db.Text
  customFields  Json?
  // Activity
  interactions  LeadInteraction[]
  lastContactedAt DateTime?
  contactCount  Int      @default(0)
  // Newsletter
  newsletterOptIn Boolean @default(false)
  optInAt       DateTime?
  unsubscribedAt DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  @@index([status, score])
  @@index([newsletterOptIn])
}

model LeadInteraction {
  id         String   @id @default(cuid())
  leadId     String
  lead       Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  type       String   // email-sent | email-opened | call | meeting | note
  subject    String?
  content    String?  @db.Text
  externalId String?
  metadata   Json?
  createdAt  DateTime @default(now())
  @@index([leadId, createdAt])
}

// ─── FORMS ─────────────────────────────────────────────────────

model FormConfig {
  id         String   @id @default(cuid())
  slug       String   @unique
  name       String
  fields     Json     // [{ name, label, type, required, ... }]
  notifyEmails String[] @default([])
  webhookUrl String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model FormSubmission {
  id        String   @id @default(cuid())
  formSlug  String
  data      Json
  ip        String?
  userAgent String?
  spam      Boolean  @default(false)
  createdAt DateTime @default(now())
  @@index([formSlug, createdAt])
}

// ─── ARTICLES / BLOG ────────────────────────────────────────────

model Article {
  id          String    @id @default(cuid())
  slug        String    @unique
  title       String
  excerpt     String?
  content     Json?
  bodyHtml    String?   @db.Text
  coverImage  String?
  images      String[]  @default([])
  videoPrompt String?   @db.Text
  status      String    @default("draft") // draft | published | scheduled
  authorName  String?
  publishedAt DateTime?
  scheduledFor DateTime?
  tags        String[]  @default([])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  @@index([status, publishedAt])
}

// ─── NEWSLETTER & EMAIL ─────────────────────────────────────────

model Newsletter {
  id          String   @id @default(cuid())
  subject     String
  bodyHtml    String?  @db.Text
  bodyText    String?  @db.Text
  status      String   @default("draft") // draft | scheduled | sending | sent
  scheduledFor DateTime?
  sentAt      DateTime?
  segments    String[] @default([])
  recipients  Int      @default(0)
  opens       Int      @default(0)
  clicks      Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model EmailTemplate {
  id        String   @id @default(cuid())
  name      String
  type      String   // welcome | newsletter | reset | custom
  subject   String?
  body      String   @db.Text
  variables String[] @default([])
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MailAccount {
  id           String   @id @default(cuid())
  label        String
  email        String   @unique
  imapHost     String
  imapPort     Int      @default(993)
  imapSecure   Boolean  @default(true)
  imapUser     String
  imapPassword String
  smtpHost     String
  smtpPort     Int      @default(465)
  smtpSecure   Boolean  @default(true)
  smtpUser     String
  smtpPassword String
  signature    String?  @db.Text
  isDefault    Boolean  @default(false)
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ─── E-COMMERCE (optionnel — disponible à l'activation) ─────────

model Product {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String?  @db.Text
  priceCents  Int
  currency    String   @default("EUR")
  images      String[] @default([])
  inventory   Int      @default(0)
  category    String?
  variants    Json?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  orderItems  OrderItem[]
}

model Order {
  id              String   @id @default(cuid())
  externalId      String?  // stripe payment intent id (or session id)
  email           String
  firstName       String?
  lastName        String?
  phone           String?
  // Shipping address
  shipAddress     String?
  shipCity        String?
  shipPostal      String?
  shipCountry     String?
  // Money (cents)
  subtotalCents   Int      @default(0)
  shippingCents   Int      @default(0)
  taxCents        Int      @default(0)
  totalCents      Int
  currency        String   @default("EUR")
  // Status workflow: pending | paid | shipped | delivered | refunded | cancelled
  status          String   @default("pending")
  // Items snapshot (denormalized — survives product deletion)
  items           Json     // [{ productId, name, qty, priceCents }]
  // Shipping tracking
  trackingNumber  String?
  trackingUrl     String?
  carrier         String?  // boxtal, shippo, dhl, ups...
  shippedAt       DateTime?
  deliveredAt     DateTime?
  // Refunds
  refundedCents   Int      @default(0)
  refundedAt      DateTime?
  // Dropship
  dropshipProvider String? // aliexpress, spocket, printful
  dropshipOrderId  String?
  dropshipStatus   String?
  // Customer tracking token (for /orders/track/[token])
  trackToken      String   @unique @default(cuid())
  // Metadata
  notes           String?  @db.Text
  metadata        Json?
  // Legacy compat (used by Stripe webhook checkout sessions)
  stripeSessionId String?  @unique
  shippingAddress Json?
  billingAddress  Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  @@index([status, createdAt])
  @@index([email])
}

// OrderItem garde la relation produit pour les pages catalogue, mais
// `items` (Json) sur Order reste la source de vérité pour l'affichage commande.
model OrderItem {
  id          String   @id @default(cuid())
  orderId     String
  productId   String
  quantity    Int
  priceCents  Int
  variant     Json?
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product     Product  @relation(fields: [productId], references: [id])
}

// ─── ASSETS (images uploadées dans MinIO bucket du tenant) ──────

model Asset {
  id         String   @id @default(cuid())
  bucket     String   // "tenant-arnaud"
  key        String   // "uploads/2026/05/photo.jpg"
  url        String?  // CDN URL
  filename   String
  mimeType   String
  sizeBytes  Int
  width      Int?
  height     Int?
  alt        String?
  // Tags & organization
  tags       String[] @default([])
  folder     String?
  // AI metadata
  aiGenerated Boolean @default(false)
  aiPrompt   String?  @db.Text
  createdAt  DateTime @default(now())
  @@index([folder])
  @@index([tags])
}

// ─── TASKS / KANBAN ────────────────────────────────────────────

model Task {
  id          String   @id @default(cuid())
  title       String
  description String?  @db.Text
  status      String   @default("todo") // todo | doing | review | done
  priority    String   @default("normal") // low | normal | high | urgent
  assignee    String?  // user id ou email
  dueDate     DateTime?
  tags        String[] @default([])
  position    Int      @default(0)
  parentId    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  @@index([status])
  @@index([assignee])
}

// ─── FORUM / DISCUSSIONS ───────────────────────────────────────

model ForumCategory {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String?
  icon        String?
  color       String?
  position    Int      @default(0)
  threads     ForumThread[]
  createdAt   DateTime @default(now())
}

model ForumThread {
  id          String   @id @default(cuid())
  categoryId  String?
  category    ForumCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  title       String
  slug        String   @unique
  body        String?  @db.Text
  authorEmail String?
  authorName  String?
  pinned      Boolean  @default(false)
  locked      Boolean  @default(false)
  views       Int      @default(0)
  posts       ForumPost[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  @@index([categoryId])
}

model ForumPost {
  id          String   @id @default(cuid())
  threadId    String
  thread      ForumThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  body        String   @db.Text
  authorEmail String?
  authorName  String?
  parentId    String?  // pour replies
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  @@index([threadId])
}

// ─── SITEMAP / NAVIGATION ──────────────────────────────────────

model SitemapEntry {
  id          String   @id @default(cuid())
  path        String
  label       String
  parentId    String?
  position    Int      @default(0)
  visibleNav  Boolean  @default(true)
  visibleSEO  Boolean  @default(true)
  changefreq  String?  // always | hourly | daily | weekly | monthly | yearly | never
  priority    Float?   // 0.0 - 1.0
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  @@unique([path])
}

// ─── DOMAINS (custom domain mapping) ───────────────────────────

model TenantDomain {
  id          String   @id @default(cuid())
  hostname    String   @unique
  primary     Boolean  @default(false)
  verifiedAt  DateTime?
  challenge   String?  // dns or http challenge token
  createdAt   DateTime @default(now())
}

// ─── 2FA SECRET (per-user TOTP) ────────────────────────────────

model TwoFactorSecret {
  id          String   @id @default(cuid())
  userEmail   String   @unique
  secret      String   // base32
  enabled     Boolean  @default(false)
  recoveryCodes String[] @default([])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─── EVENTS / AGENDA ───────────────────────────────────────────

model Event {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  description String?  @db.Text
  startsAt    DateTime
  endsAt      DateTime?
  location    String?
  lat         Float?
  lng         Float?
  coverImage  String?
  category    String?
  tags        String[] @default([])
  externalUrl String?
  published   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  @@index([startsAt])
  @@index([category])
}

// ─── COUPONS / PROMOS ──────────────────────────────────────────

model Coupon {
  id                   String   @id @default(cuid())
  code                 String   @unique
  type                 String   @default("percent") // percent | fixed
  value                Int      @default(0)
  currency             String   @default("EUR")
  minCents             Int?
  maxUses              Int?
  usedCount            Int      @default(0)
  validFrom            DateTime?
  validUntil           DateTime?
  active               Boolean  @default(true)
  applicableProductIds String[] @default([])
  notes                String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  @@index([active])
}

// ─── TESTIMONIALS / TÉMOIGNAGES VIDÉO ──────────────────────────

model Testimonial {
  id           String   @id @default(cuid())
  authorName   String
  authorTitle  String?
  authorAvatar String?
  videoUrl     String?
  posterImage  String?
  quote        String?  @db.Text
  rating       Int?
  tags         String[] @default([])
  featured     Boolean  @default(false)
  published    Boolean  @default(true)
  position     Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  @@index([published, position])
}

// ─── YOUTUBE VIDEOS ────────────────────────────────────────────

model YoutubeVideo {
  id          String   @id @default(cuid())
  videoId     String   @unique // 11-char YouTube id
  title       String
  description String?  @db.Text
  thumbnail   String?
  channel     String?
  publishedAt DateTime?
  category    String?
  featured    Boolean  @default(false)
  position    Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  @@index([position])
}

// ─── BANNERS / HERO ────────────────────────────────────────────

model Banner {
  id          String   @id @default(cuid())
  name        String
  image       String?
  link        String?
  ctaLabel    String?
  position    String   @default("hero") // top | hero | inline | bottom
  priority    Int      @default(0)
  startsAt    DateTime?
  endsAt      DateTime?
  active      Boolean  @default(true)
  targetPages String[] @default([])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  @@index([active, position])
}

// ─── MAP LOCATIONS (lieux géolocalisés) ───────────────────────

model MapLocation {
  id           String   @id @default(cuid())
  name         String
  type         String?
  address      String?
  lat          Float
  lng          Float
  country      String?
  city         String?
  description  String?  @db.Text
  featured     Boolean  @default(false)
  openingHours Json?
  contact      Json?
  images       String[] @default([])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  @@index([type])
  @@index([country, city])
}

// ─── MODERATION QUEUE ─────────────────────────────────────────

model ModerationItem {
  id          String   @id @default(cuid())
  type        String   // forum-post | comment | review | message
  targetId    String?
  content     String?  @db.Text
  authorName  String?
  authorEmail String?
  status      String   @default("pending") // pending | approved | rejected | flagged
  aiScore     Float?
  aiLabels    Json?
  decidedBy   String?
  decidedAt   DateTime?
  reason      String?
  createdAt   DateTime @default(now())
  @@index([status, createdAt])
  @@index([type])
}

// ─── POSTERS (affiches générées) ──────────────────────────────

model Poster {
  id        String   @id @default(cuid())
  name      String
  theme     String?
  content   Json?
  imageUrl  String?
  sizes     String[] @default([])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── NEWSLETTER PLAN (plan annuel par mois) ───────────────────

model NewsletterPlan {
  id          String   @id @default(cuid())
  year        Int
  month       Int      // 1..12
  theme       String?
  subject     String?
  audiences   String[] @default([])
  scheduledAt DateTime?
  notes       String?  @db.Text
  status      String   @default("planned") // planned | ready | sent
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  @@unique([year, month])
}

// ─── SOCIAL POSTS (calendrier social cross-réseaux) ───────────

model SocialPost {
  id           String   @id @default(cuid())
  platform     String   // instagram | facebook | linkedin | twitter | tiktok | youtube
  content      String   @db.Text
  mediaUrls    String[] @default([])
  scheduledAt  DateTime?
  publishedAt  DateTime?
  status       String   @default("draft") // draft | scheduled | published | failed
  hashtags     String[] @default([])
  externalId   String?  // id du post sur la plateforme
  errorMessage String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  @@index([scheduledAt])
  @@index([platform, status])
}

// ─── RICH PAGES (pages marketing : about, contact, terms, etc) ─

model RichPage {
  id        String   @id @default(cuid())
  slug      String   @unique
  title     String
  bodyHtml  String?  @db.Text
  meta      Json?    // { description, ogImage, robots, ... }
  status    String   @default("draft") // draft | published
  position  Int      @default(0)
  parentId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@index([status])
  @@index([parentId, position])
}

// ─── PARTNERS (logos partenaires, sponsors) ───────────────────

model Partner {
  id           String   @id @default(cuid())
  name         String
  slug         String   @unique
  logoUrl      String?
  websiteUrl   String?
  description  String?  @db.Text
  category     String?
  featured     Boolean  @default(false)
  position     Int      @default(0)
  contactName  String?
  contactEmail String?
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  @@index([active, position])
  @@index([featured])
}
