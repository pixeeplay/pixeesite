# ─── Platform DB (partagée) ──────────────────────────────────
PLATFORM_DATABASE_URL="postgresql://pixeesite:password@localhost:5432/pixeesite_platform"

# ─── Tenant DB cluster (un schéma/DB par tenant) ──────────────
# URL avec placeholder {orgSlug} qui sera remplacé à runtime
TENANT_DATABASE_URL_TEMPLATE="postgresql://pixeesite:password@localhost:5432/pixeesite_tenant_{orgSlug}"
# Pour créer/dropper les DB tenants
POSTGRES_ADMIN_URL="postgresql://postgres:postgres@localhost:5432/postgres"

# ─── Auth ────────────────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"

# OAuth providers
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# ─── Storage MinIO ───────────────────────────────────────────
MINIO_ENDPOINT="localhost"
MINIO_PORT="9000"
MINIO_ACCESS_KEY=""
MINIO_SECRET_KEY=""
MINIO_USE_SSL="false"

# ─── Redis ────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── Stripe ────────────────────────────────────────────────────
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRICE_SOLO=""
STRIPE_PRICE_PRO=""
STRIPE_PRICE_AGENCY=""

# ─── AI providers ─────────────────────────────────────────────
GEMINI_API_KEY=""
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
ELEVENLABS_API_KEY=""
FAL_KEY=""
HEYGEN_API_KEY=""

# ─── Email ────────────────────────────────────────────────────
RESEND_API_KEY=""
SMTP_HOST=""
SMTP_PORT="465"
SMTP_USER=""
SMTP_PASSWORD=""

# ─── Caddy custom domain API ──────────────────────────────────
CADDY_ADMIN_URL="http://localhost:2019"
CADDY_ADMIN_TOKEN=""

# ─── Domains ─────────────────────────────────────────────────
PLATFORM_DOMAIN="pixeesite.com"
RENDER_DOMAIN="pixeesite.app"
ADMIN_URL="https://app.pixeesite.com"
RENDER_URL="https://render.pixeesite.app"

# ─── Cron ────────────────────────────────────────────────────
CRON_TOKEN="generate-with-openssl-rand-hex-32"

# ─── Analytics ────────────────────────────────────────────────
PLAUSIBLE_URL=""
PLAUSIBLE_API_KEY=""

# ─── Dev ──────────────────────────────────────────────────────
NODE_ENV="development"
LOG_LEVEL="info"
